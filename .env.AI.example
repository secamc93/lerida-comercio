# Plantilla de credenciales para uso por la IA (Claude Code) durante testing.
# Copiar a `.env.AI` y completar con valores reales.
# `.env.AI` NO se commitea — está cubierto por .gitignore (`.env.*`).
# Convención alineada con .claude/rules/test-credentials.md.

# Super Admin (creado por el seed `back/migration/cmd/main.go`)
AI_SUPER_ADMIN_EMAIL=admin@lerida.local
AI_SUPER_ADMIN_PASSWORD=cambiar-por-password-real

# Usuario business (no super admin).
# Crear vía POST /users sin business → o asignar business con assign-role.
# Luego rotar password con POST /auth/generate-password {"user_id": N}
# y guardar aquí.
AI_DEMO_EMAIL=
AI_DEMO_PASSWORD=

# Base URLs
AI_BACKEND_URL=http://localhost:3050/api/v1
AI_FRONTEND_URL=http://localhost:3000

# Uso:
#   set -a && source .env.AI && set +a
#   curl -X POST $AI_BACKEND_URL/auth/login \
#     -H "Content-Type: application/json" -H "X-Client-Type: api" \
#     -d "{\"email\":\"$AI_SUPER_ADMIN_EMAIL\",\"password\":\"$AI_SUPER_ADMIN_PASSWORD\"}"
