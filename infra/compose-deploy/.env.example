# Variables del stack de producción en el EC2.
# Copiar a `.env` (no se commitea) y rellenar con valores reales.

# Repositorio ECR (sin tag)
ECR_REPO=334689162817.dkr.ecr.us-east-1.amazonaws.com/lerida-comercio

# Base de datos
DB_USER=lerida
DB_PASS=cambiar-por-password-seguro
DB_NAME=lerida_comercio

# Auth
JWT_SECRET=cambiar-por-secreto-de-64-hex

# CORS — origen público del frontend
CORS_ALLOWED_ORIGINS=http://ec2-34-235-36-96.compute-1.amazonaws.com
